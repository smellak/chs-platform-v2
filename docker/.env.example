# Database
DATABASE_URL=postgresql://aleph:aleph_secret@db:5432/aleph
POSTGRES_PASSWORD=aleph_secret

# Auth
JWT_SECRET=change-me-in-production-use-at-least-64-chars-random
# Generate with: openssl rand -hex 64

# Organization (used by seed on first run)
ORG_NAME=My Company
ORG_SLUG=my-company
ORG_DOMAIN=

# Domain for cross-domain cookies (leave empty for localhost)
DOMAIN=

# AI Agent (optional — leave ANTHROPIC_API_KEY empty to disable)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096
AI_RATE_LIMIT_MESSAGES_PER_HOUR=50
AI_RATE_LIMIT_TOKENS_PER_DAY=100000

# Node
NODE_ENV=production
PORT=3000
